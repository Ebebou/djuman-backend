const nodemailer = require("nodemailer");
require("dotenv").config();

// ============================================
// TRANSPORTEUR — Relais SMTP Brevo
// ============================================
const transporter = nodemailer.createTransport({
  host: process.env.EMAIL_HOST,
  port: parseInt(process.env.EMAIL_PORT, 10),
  secure: false, // TLS (STARTTLS) via le port 587
  auth: {
    user: process.env.EMAIL_USER,
    pass: process.env.EMAIL_PASS, // ✅ "pass" et non "password" — Nodemailer attend exactement cette clé
  },
});

// ============================================
// TEMPLATE DE BASE — Wrapper HTML réutilisable
// Toutes les futures campagnes peuvent réutiliser ce wrapper visuel
// ============================================
function buildEmailWrapper(contentHTML) {
  return `
    <div style=   @font-face {
            font-family: 'Galano Grotesque';
            src: url('data:font/woff2;charset=utf-8;base64,') format('woff2');s  "background-color:#F6F4E6; padding:30px 0; font-family:'Galano Grotesque', Arial, sans-serif;">
        <div style="max-width:600px; margin:0 auto; padding:30px; border:1px solid #e2e8f0; border-radius:12px; background-color:#ffffff;">
            <div style="text-align:center; margin-bottom:25px;">
                <img src="https://djuman.vercel.app/assets/image/logo_rectangle_bleu.svg" alt="Djuman" style="height:36px;">
            </div>
            <hr style="border:0; height:1px; background:#e2e8f0; margin-bottom:25px;" />
            ${contentHTML}
            <p style="font-size:13px; color:#94a3b8; text-align:center; margin-top:40px;">
                Djuman · Abidjan, Côte d'Ivoire<br>
                Vous recevez cet email car vous êtes inscrit(e) sur djuman.com
            </p>
        </div>
    </div>`;
}

// ============================================
// EMAIL DE BIENVENUE — Envoi unitaire (inscription waitlist)
// ============================================
exports.sendWelcomeEmail = async (toEmail, prenom) => {
  const content = `
        <p style="font-size:16px; color:#334155; line-height:1.6;">Bonjour <strong>${prenom}</strong>,</p>
        <p style="font-size:16px; color:#334155; line-height:1.6;">Merci pour votre inscription sur la liste d'attente exclusive de <strong>Djuman</strong> !</p>
        <p style="font-size:16px; color:#334155; line-height:1.6;">Nous mettons la dernière touche à la solution de gestion tout-en-un conçue pour simplifier le pilotage de vos stocks, le calcul de vos finances et l'organisation de vos ventes au quotidien, de manière fluide et ultra-légère.</p>
        <p style="font-size:16px; color:#334155; line-height:1.6;">En tant que membre de la Waitlist, vous ferez partie des tout premiers à être notifiés lors du lancement officiel et bénéficierez d'avantages préférentiels exclusifs.</p>
        <div style="margin:35px 0; text-align:center;">
            <span style="background-color:#629A72; color:white; padding:12px 24px; font-weight:bold; border-radius:6px; font-size:14px; letter-spacing:0.5px;">
                INSCRIPTION CONFIRMÉE
            </span>
        </div>
        <p style="font-size:15px; color:#64748b; line-height:1.6; margin-top:30px;">À très bientôt,</p>
        <p style="font-size:15px; color:#2B323E; font-weight:bold; margin:0;">L'équipe Djuman</p>
    `;

  const mailOptions = {
    from: `"Djuman" <${process.env.EMAIL_USER}>`,
    to: toEmail,
    subject:
      "Bienvenue sur Djuman — Préparez-vous à propulser votre commerce !",
    html: buildEmailWrapper(content),
  };

  try {
    const info = await transporter.sendMail(mailOptions);
    console.log(
      `✅ Email de bienvenue envoyé à ${toEmail} (ID: ${info.messageId})`
    );
    return info;
  } catch (error) {
    console.error(`❌ Échec envoi email vers ${toEmail} :`, error.message);
    throw error;
  }
};

// ============================================
// EMAIL DE CAMPAGNE — Envoi groupé (newsletter / mise à jour)
// Utilisé plus tard depuis le dashboard admin pour communiquer
// avec tous les inscrits ou une sélection d'entre eux.
// ============================================
exports.sendCampaignEmail = async (recipients, subject, bodyHTML) => {
  const content = `
        <div style="font-size:16px; color:#334155; line-height:1.7;">
            ${bodyHTML}
        </div>
    `;

  const html = buildEmailWrapper(content);

  // Envoi en série pour respecter les limites de débit de Brevo
  // et éviter d'exposer tous les emails dans un seul champ "to"
  const results = { sent: [], failed: [] };

  for (const toEmail of recipients) {
    try {
      const info = await transporter.sendMail({
        from: `"Djuman" <${process.env.EMAIL_USER}>`,
        to: toEmail,
        subject,
        html,
      });
      results.sent.push(toEmail);
      console.log(`✅ Campagne envoyée à ${toEmail} (ID: ${info.messageId})`);
    } catch (error) {
      results.failed.push({ email: toEmail, error: error.message });
      console.error(`❌ Échec campagne vers ${toEmail} :`, error.message);
    }
  }

  return results;
};

// ============================================
// VÉRIFICATION DE CONNEXION SMTP — Utile pour debug
// ============================================
exports.verifyConnection = async () => {
  try {
    await transporter.verify();
    console.log("✅ Connexion SMTP Brevo vérifiée avec succès.");
    return true;
  } catch (error) {
    console.error("❌ Erreur de connexion SMTP :", error.message);
    return false;
  }
};
